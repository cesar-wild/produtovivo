# Server
PORT=8082
NODE_ENV=production

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/produtovivo

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Resend (email)
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@produtovivo.com
SUPPORT_EMAIL=suporte@produtovivo.com

# App
APP_URL=https://produtovivo.com
DOWNLOAD_SECRET=change_this_to_random_secret

# Hotmart webhook
HOTMART_SECRET=your_hottok_here

# Meta Conversions API (server-side Purchase events)
META_PIXEL_ID=4520253334926563
META_ACCESS_TOKEN=your_meta_access_token_here

# Manual CAPI trigger (Kiwify or other platforms)
MANUAL_WEBHOOK_SECRET=change_this_to_random_secret

# Resend webhook signature (Svix secret from Resend dashboard)
RESEND_WEBHOOK_SECRET=whsec_...
